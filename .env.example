# Copy this file to .env and fill in the secret values.
# Do not commit .env.

# W&B authentication and logging.
WANDB_API_KEY=
WANDB_PROJECT=qwen-omd
WANDB_ENTITY=
WANDB_MODE=online
WANDB_LOG_BEST_CHECKPOINTS=true
UPLOAD_FINAL_CHECKPOINTS_TO_WANDB=true
UPLOAD_FINAL_CHECKPOINTS_ON_FAILURE=false

# Vast.ai teardown. Enable only when you are sure outputs are uploaded.
VAST_API_KEY=
VAST_INSTANCE_ID=
DESTROY_VAST_INSTANCE_ON_EXIT=false
DESTROY_VAST_INSTANCE_ON_FAILURE=false

# Setup script defaults.
WORKSPACE_DIR=/workspace
REPO_URL=https://github.com/amitf1/online_mistake_detection.git
BUILD_DOCKER_IMAGE=false
IMAGE_NAME=amitfe/qwen-omd-dataloaders:latest

# Optional: copy the 11GB video tree to /dev/shm before training.
# Requires Docker option like --shm-size=32g or larger.
COPY_VIDEOS_TO_SHM=false
SHM_VIDEO_ROOT=/dev/shm/ego_oops_videos

# Module-specific run defaults are tracked in .env.module_a and .env.module_b.
# Edit them directly when changing non-secret training defaults.

# Module B temporal grounding.
# Use scripts/run_module_b_docker.sh locally or scripts/run_module_b_vastai.sh on Vast.ai.
# Suggested Module B smoke overrides:
# RUN_NAME=module_b_smoke MAX_VIDEOS=2 MAX_FRAMES=16 VISION_RESIZE=384 MAX_SEQ_LENGTH=3072 TRAIN_MODE=steps MAX_STEPS=2 REGENERATE_SPLIT=true SPLIT_FILE=/tmp/module_b_smoke_split.json

# Suggested Module B 80/96GB starting point:
# RUN_NAME=module_b_9b_frames128_resize512_epoch30 MODEL_NAME=unsloth/Qwen3.5-9B LOAD_IN_16BIT=true MAX_FRAMES=128 VISION_RESIZE=512 MAX_SEQ_LENGTH=24576 TRAIN_MODE=epochs NUM_TRAIN_EPOCHS=30
