# Module C mistake detection and reasoning defaults.
# 48GB recommended starting point, based on Module B memory behavior:
# keep resize quality at 512, but cap train/eval frames lower than the earlier 32/24 attempt.
RUN_NAME=module_c_48gb_2b_r32_train24_eval16_resize512_seq8192
MODEL_NAME=unsloth/Qwen3.5-2B
LOAD_IN_4BIT=false
LOAD_IN_16BIT=true
LORA_R=32
LORA_ALPHA=64
LORA_DROPOUT=0.0
# LoRA target interface:
# - LORA_TARGET_MODULES=auto respects the FINETUNE_* flags below.
# - LORA_TARGET_MODULES=all-linear is only valid when all FINETUNE_* flags are true.
LORA_TARGET_MODULES=auto
MAX_FRAMES=24
EVAL_MAX_FRAMES=16
VISION_RESIZE=512
MAX_SEQ_LENGTH=8192
MODULE_C_MIN_DURATION_SECONDS=0.5
MODULE_C_JITTER_RATIO_MIN=0.05
MODULE_C_JITTER_RATIO_MAX=0.10
# Output paths (run scripts expand literal ${RUN_NAME} in OUTPUT_DIR after env load).
OUTPUT_ROOT=/home/amit/online_mistake_detection/outputs
OUTPUT_DIR=/home/amit/online_mistake_detection/outputs/module_c_qwen35_lora_reasoning/runs/${RUN_NAME}
TRAIN_MODE=epochs
NUM_TRAIN_EPOCHS=10
EVAL_EPOCHS=1
CHECKPOINT_EPOCHS=1
KEEP_LAST_CHECKPOINTS=2
KEEP_BEST_CHECKPOINTS=2
METRIC_FOR_BEST_MODEL=eval_mistake/f1
GREATER_IS_BETTER=true
EARLY_STOPPING_PATIENCE=3
EVAL_GENERATION_MAX_NEW_TOKENS=128
FINETUNE_VISION_LAYERS=false
FINETUNE_LANGUAGE_LAYERS=true
FINETUNE_ATTENTION_MODULES=true
FINETUNE_MLP_MODULES=true

# Language-only LoRA example:
# LORA_TARGET_MODULES=auto FINETUNE_VISION_LAYERS=false FINETUNE_LANGUAGE_LAYERS=true FINETUNE_ATTENTION_MODULES=true FINETUNE_MLP_MODULES=true
#
# Full vision+language LoRA example:
# LORA_TARGET_MODULES=all-linear FINETUNE_VISION_LAYERS=true FINETUNE_LANGUAGE_LAYERS=true FINETUNE_ATTENTION_MODULES=true FINETUNE_MLP_MODULES=true

# Local 16GB recommended starting point, based on Module B fallbacks:
# DATA_ROOT=/home/amit/online_mistake_detection/data/videos-processed-720p RUN_NAME=module_c_16gb_2b_r16_16f384_seq3072 LORA_TARGET_MODULES=auto FINETUNE_VISION_LAYERS=false LORA_R=16 LORA_ALPHA=32 MAX_FRAMES=16 EVAL_MAX_FRAMES=16 VISION_RESIZE=384 MAX_SEQ_LENGTH=3072 TRAIN_MODE=epochs NUM_TRAIN_EPOCHS=10 REPORT_TO=tensorboard WANDB_LOG_BEST_CHECKPOINTS=false bash qwen_ego_oops_lora_dataloaders/scripts/run_module_c_docker.sh
#
# Optional preflight token-length report, run outside training but inside the Docker image:
# DATA_ROOT=/home/amit/online_mistake_detection/data/videos-processed-720p MEASURE_MAX_FRAMES="16 24 32" MEASURE_EVAL_MAX_FRAMES="16" VISION_RESIZE=384 MEASURE_SEQ_LENGTHS="3072 4096 5120 6144 8192" bash qwen_ego_oops_lora_dataloaders/scripts/measure_module_c_seq_lengths_docker.sh
#
# 48GB run command:
# DATA_ROOT=/home/amit/online_mistake_detection/data/videos-processed-720p REPORT_TO=wandb WANDB_LOG_BEST_CHECKPOINTS=true bash qwen_ego_oops_lora_dataloaders/scripts/run_module_c_docker.sh
