# Module A step_id training defaults (local 16GB / Qwen3.5-2B).
# Seq lengths locked from measure reports:
#   16f@384 full: module_a_seq_lengths_16gb.json (max~2007 → seq3072)
#   24/32f@512 stress: module_a_seq_lengths_512_stress.json
#     24f max~3953 → seq4096 fits; use 5120 for margin
#     32f max~5021 → seq5120 fits; use 6144 for margin
RUN_NAME=module_a_step_id_16gb_2b_r16_16f384_seq3072
MODEL_NAME=unsloth/Qwen3.5-2B
LOAD_IN_4BIT=false
LOAD_IN_16BIT=true
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.0
# LoRA target interface:
# - LORA_TARGET_MODULES=auto respects the FINETUNE_* flags below.
# - LORA_TARGET_MODULES=all-linear is only valid when all FINETUNE_* flags are true.
LORA_TARGET_MODULES=all-linear
MAX_FRAMES=16
VISION_RESIZE=384
MAX_SEQ_LENGTH=3072
MODULE_A_LABEL_MODE=step_id
TRAIN_MODE=epochs
NUM_TRAIN_EPOCHS=30
EVAL_EPOCHS=1
CHECKPOINT_EPOCHS=1
KEEP_LAST_CHECKPOINTS=2
KEEP_BEST_CHECKPOINTS=2
EARLY_STOPPING_PATIENCE=3
# Multiclass letter macro-F1 for checkpointing; binary gate F1 still logged as eval_detection/f1.
METRIC_FOR_BEST_MODEL=eval_step_id/macro_f1
GREATER_IS_BETTER=true
FINETUNE_VISION_LAYERS=true
FINETUNE_LANGUAGE_LAYERS=true
FINETUNE_ATTENTION_MODULES=true
FINETUNE_MLP_MODULES=true
REPORT_TO=tensorboard

# Optional Module A recall-bias controls (non-A treated as positives in step_id mode).
POSITIVE_OVERSAMPLE_FACTOR=1.0
POSITIVE_LOSS_WEIGHT=2.0
FBETA_BETA=2.0
LABEL_SCORE_EVAL=false

# Language-only LoRA example:
# LORA_TARGET_MODULES=auto FINETUNE_VISION_LAYERS=false FINETUNE_LANGUAGE_LAYERS=true FINETUNE_ATTENTION_MODULES=true FINETUNE_MLP_MODULES=true
#
# Full vision+language LoRA example:
# LORA_TARGET_MODULES=all-linear FINETUNE_VISION_LAYERS=true FINETUNE_LANGUAGE_LAYERS=true FINETUNE_ATTENTION_MODULES=true FINETUNE_MLP_MODULES=true

# --- 48GB step_id (measured 24f@512 stress max~3953; 4096 OK, 5120 recommended) ---
# RUN_NAME=module_a_step_id_48gb_2b_r32_24f512_seq5120
# LORA_R=32 LORA_ALPHA=64 MAX_FRAMES=24 VISION_RESIZE=512 MAX_SEQ_LENGTH=5120
# MODULE_A_LABEL_MODE=step_id REPORT_TO=wandb WANDB_LOG_BEST_CHECKPOINTS=true

# --- 96GB 2B step_id (measured 32f@512 stress max~5021; 5120 OK, 6144 recommended) ---
# RUN_NAME=module_a_step_id_96gb_2b_r32_32f512_seq6144
# LORA_R=32 LORA_ALPHA=64 MAX_FRAMES=32 VISION_RESIZE=512 MAX_SEQ_LENGTH=6144
# MODULE_A_LABEL_MODE=step_id

# --- 96GB 9B heavy (optional; 128f@512 not re-measured — keep large seq budget) ---
# RUN_NAME=module_a_9b_frames128_resize512_epoch30
# MODEL_NAME=unsloth/Qwen3.5-9B
# LORA_R=8 LORA_ALPHA=16 LORA_TARGET_MODULES=all-linear
# MAX_FRAMES=128 VISION_RESIZE=512 MAX_SEQ_LENGTH=24576
# FINETUNE_VISION_LAYERS=true FINETUNE_LANGUAGE_LAYERS=true
# FINETUNE_ATTENTION_MODULES=true FINETUNE_MLP_MODULES=true
# MODULE_A_LABEL_MODE=step_id

