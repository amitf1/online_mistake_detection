# Module A 96GB 9B training defaults.
RUN_NAME=module_a_9b_frames128_resize512_epoch30
MODEL_NAME=unsloth/Qwen3.5-9B
LOAD_IN_4BIT=false
LOAD_IN_16BIT=true
MAX_FRAMES=128
VISION_RESIZE=512
MAX_SEQ_LENGTH=24576
TRAIN_MODE=epochs
NUM_TRAIN_EPOCHS=30
EVAL_EPOCHS=1
CHECKPOINT_EPOCHS=1
KEEP_LAST_CHECKPOINTS=5
KEEP_BEST_CHECKPOINTS=5
EARLY_STOPPING_PATIENCE=3
FINETUNE_VISION_LAYERS=true

# Optional Module A recall-bias controls.
POSITIVE_OVERSAMPLE_FACTOR=1.0 # Set to a value greater than 1.0 for module A recall-bias training.
POSITIVE_LOSS_WEIGHT=1.0 # Set to a value greater than 1.0 for module A recall-bias training.
FBETA_BETA=2.0 # Set to a value greater than 1.0 for module A recall-bias training.
LABEL_SCORE_EVAL=false # Set to true for module A recall-bias training. Only works with UNSLOTH_RETURN_LOGITS=1 and UNSLOTH_RETURN_HIDDEN_STATES=1.
