# Module B temporal grounding defaults.
RUN_NAME=module_b_48gb_2b_r32_32f512_seq8192
MODEL_NAME=unsloth/Qwen3.5-2B
LOAD_IN_4BIT=false
LOAD_IN_16BIT=true
LORA_R=32
LORA_ALPHA=64
LORA_DROPOUT=0.0
# LoRA target interface:
# - LORA_TARGET_MODULES=auto respects the FINETUNE_* flags below.
# - LORA_TARGET_MODULES=all-linear is only valid when all FINETUNE_* flags are true.
LORA_TARGET_MODULES=auto
MAX_FRAMES=32
EVAL_MAX_FRAMES=24
VISION_RESIZE=512
MAX_SEQ_LENGTH=8192
INCLUDE_INCOMPLETE_NEGATIVES=true
MODULE_B_NEGATIVE_RATIO=0.10
TRAIN_MODE=epochs
NUM_TRAIN_EPOCHS=5
EVAL_EPOCHS=1
CHECKPOINT_EPOCHS=1
KEEP_LAST_CHECKPOINTS=4
KEEP_BEST_CHECKPOINTS=4
METRIC_FOR_BEST_MODEL=eval_temporal/mean_iou
GREATER_IS_BETTER=true
EARLY_STOPPING_PATIENCE=3
FINETUNE_VISION_LAYERS=false
FINETUNE_LANGUAGE_LAYERS=true
FINETUNE_ATTENTION_MODULES=true
FINETUNE_MLP_MODULES=true

# Language-only LoRA example:
# LORA_TARGET_MODULES=auto FINETUNE_VISION_LAYERS=false FINETUNE_LANGUAGE_LAYERS=true FINETUNE_ATTENTION_MODULES=true FINETUNE_MLP_MODULES=true
#
# Full vision+language LoRA example:
# LORA_TARGET_MODULES=all-linear FINETUNE_VISION_LAYERS=true FINETUNE_LANGUAGE_LAYERS=true FINETUNE_ATTENTION_MODULES=true FINETUNE_MLP_MODULES=true
